@page
@model WeatherWebAppLuiC.Pages.IndexModel
@{
    ViewData["Title"] = "Search";
}

<!--
Index page for the weather web app. 

The index page contains the hero image, search bar, weather around the world and links to the Project Info/Survey Link. 
A div class for the hero wrapper image in order to display the hero image. (MDN Contributors, 2025b)
An input element (MDN Contributors, 2025e) is used for the search bar, styling the search bar to give its full apperance for the user, and accepts written input for the city/town.
The form element (Refsnes Data, 2026d) is placed here, to allow input from the user. The information received here is processed for the Models in the weather web app.
A button element (Refsnes Data, 2026c), which allows the user to click in order to progress to the weather results page. 

An if and else logic for the Razor page is created in order to display the weather around the world (Refsnes Data, 2026b). The else condition handles the exception or in a scenario where the weather web app is unable to show a weather icon or condition and defaults to a cloudy condition from the OpenWeather API. (OpenWeather, 2026)
The autocomplete functionality is explained in their respective CSS and JS files. 

Finally, a table is created to display the weather conditions around the world, with a list of pre-defined cities. (Refsnes Data, 2026f)

-->

<div class="text-center">
    <h1 class="display-4">Welcome to the Weather Web App</h1>
</div>

<div class="hero-wrapper" style="position:relative; width:100vw; margin-left:calc(50% - 50vw); margin-right:calc(50% - 50vw); overflow:hidden;">
    <img src="/Images/Main/20250401_190146.jpg" alt="London Skyline Sunny Weather" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center; z-index:0;" />
    <div class="hero-content">
        <form method="post" style="width:90%; max-width:900px; background-image: linear-gradient(126.6deg, rgba(44,115,210,1) 3.4%, rgba(251,234,255,1) 127.9%); padding:16px; border-radius:10px; box-shadow:0 6px 20px rgba(0,0,0,0.18); transform: translateY(-2vh);">
            <input asp-for="City" id="CityInput" type="text" class="form-control d-inline-block w-100" placeholder="Input city here!" style="max-width:850px;" />
            <input asp-for="Lat" type="hidden" id="Lat" />
            <input asp-for="Lon" type="hidden" id="Lon" />
            <div id="city-suggestions" class="autocomplete-items" style="position:relative; z-index:1000;"></div>
            <div style="text-align:center; margin-top:8px;"><button type="submit" class="center-button">Search City</button></div>
        </form>
    </div>
    <p style="position: absolute; bottom: 12px; left: 16px; margin:0; color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,0.6); z-index:2;">Image of Greenwich Park (Lui Contreras, 2025)</p>
</div>
<table class="caption-top simple-weather-table" style="width:100%; max-width:900px; margin:1rem auto; border-collapse:collapse;">
    <caption>Weather around the world</caption>
        <tr>
            <th>New York</th>
            <th>London</th>
            <th>Tokyo</th>
            <th>Belfast</th>
            <th>Dublin</th>
        </tr>
    </thead>
    <tbody>
        <tr style="text-align:center;">
            @if (Model.PreloadedWeathers != null && Model.PreloadedWeathers.Count >= 5)
            {
                <td><img id="icon-newyork" src="@Model.PreloadedWeathers[0].HourlyForecast[0].IconName" alt="@Model.PreloadedWeathers[0].WeatherDescription" style="width:48px;height:auto;" /></td>
                <td><img id="icon-london" src="@Model.PreloadedWeathers[1].HourlyForecast[0].IconName" alt="@Model.PreloadedWeathers[1].WeatherDescription" style="width:48px;height:auto;" /></td>
                <td><img id="icon-japan" src="@Model.PreloadedWeathers[2].HourlyForecast[0].IconName" alt="@Model.PreloadedWeathers[2].WeatherDescription" style="width:48px;height:auto;" /></td>
                <td><img id="icon-belfast" src="@Model.PreloadedWeathers[3].HourlyForecast[0].IconName" alt="@Model.PreloadedWeathers[3].WeatherDescription" style="width:48px;height:auto;" /></td>
                <td><img id="icon-dublin" src="@Model.PreloadedWeathers[4].HourlyForecast[0].IconName" alt="@Model.PreloadedWeathers[4].WeatherDescription" style="width:48px;height:auto;" /></td>
            }
            else
            {
                <td><img id="icon-newyork" src="https://openweathermap.org/img/wn/03d@2x.png" alt="New York" style="width:48px;height:auto;" /></td>
                <td><img id="icon-london" src="https://openweathermap.org/img/wn/03d@2x.png" alt="London" style="width:48px;height:auto;" /></td>
                <td><img id="icon-japan" src="https://openweathermap.org/img/wn/03d@2x.png" alt="Tokyo" style="width:48px;height:auto;" /></td>
                <td><img id="icon-belfast" src="https://openweathermap.org/img/wn/03d@2x.png" alt="Belfast" style="width:48px;height:auto;" /></td>
                <td><img id="icon-dublin" src="https://openweathermap.org/img/wn/03d@2x.png" alt="Dublin" style="width:48px;height:auto;" /></td>
            }
        </tr>
    </tbody>
</table>

@if (Model.Weather != null)
{
    <div class="mt-3 text-center">
        <strong>@Model.Weather.City</strong>: @Model.Weather.WeatherDescription, @Model.Weather.TempsDisplay
    </div>
}



<!-- Ensures site.js is loaded for autocomplete functionality -->
<script src="~/js/site.js"></script>